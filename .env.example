# GameLens AI - example environment file
# ---------------------------------------------------------------
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
# Never commit your real ".env" file (it is already in .gitignore).

# Required to enable the LLM agents (Data Analyst, Sports Insight, QA).
# The app STILL RUNS without this key - it just shows a rule-based
# fallback instead of GPT-4o Mini text.
OPENAI_API_KEY=your_openai_api_key_here

# Optional. Defaults to gpt-4o-mini if left unset.
OPENAI_MODEL=gpt-4o-mini
